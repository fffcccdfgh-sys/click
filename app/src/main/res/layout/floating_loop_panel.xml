<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/loopSettingsPanel"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/floating_panel_bg"
    android:elevation="4dp"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/loopPanelDragHandle"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:text="@string/loop_button"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/loop_count_label"
                android:textColor="#CBD5E1"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/loopCountInput"
                android:layout_width="148dp"
                android:layout_height="36dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/floating_input_bg"
                android:hint="@string/loop_count_hint"
                android:inputType="number"
                android:maxLength="8"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="#334155"
                android:textColorHint="#64748B"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/loop_gap_label"
                android:textColor="#CBD5E1"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/loopGapInput"
                android:layout_width="148dp"
                android:layout_height="36dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/floating_input_bg"
                android:hint="0"
                android:inputType="number"
                android:maxLength="8"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="#334155"
                android:textColorHint="#64748B"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/loopSettingsSave"
            style="@style/FloatingControlSuccessPill"
            android:layout_marginStart="10dp"
            android:text="@string/save" />
    </LinearLayout>
</LinearLayout>
