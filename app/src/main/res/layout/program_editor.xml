<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/programEditorRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/floating_panel_bg"
    android:elevation="4dp"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/programEditorHeader"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/programEditorTitle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:paddingStart="4dp"
            android:paddingEnd="12dp"
            android:text="@string/program_editor_title"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/programCloseButton"
            style="@style/FloatingControlDangerPill"
            android:text="@string/close_button" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/programEditorScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:id="@+id/programEditorContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/programEditToolbar"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/floating_control_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="6dp"
                android:paddingEnd="6dp">

                <TextView
                    android:id="@+id/programSelectAllButton"
                    style="@style/FloatingControlSecondaryPill"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:text="@string/program_edit_select_all"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/programCopyButton"
                    style="@style/FloatingControlSecondaryPill"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:text="@string/program_edit_copy"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/programCutButton"
                    style="@style/FloatingControlWarningPill"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:text="@string/program_edit_cut"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/programPasteButton"
                    style="@style/FloatingControlSuccessPill"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:text="@string/program_edit_paste"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/templateButton"
                    style="@style/FloatingControlPrimaryPill"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:text="@string/insert_template"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/programCodePanel"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/floating_control_bg"
                android:orientation="horizontal"
                android:padding="8dp">

                <com.fffcccdfgh.androidclicker.ProgramLineNumberView
                    android:id="@+id/programLineNumbers"
                    android:layout_width="36dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="6dp" />

                <EditText
                    android:id="@+id/programCodeInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#0B1020"
                    android:gravity="top|start"
                    android:hint="@string/program_code_hint"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:overScrollMode="always"
                    android:paddingStart="10dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="10dp"
                    android:scrollbars="none"
                    android:textColor="#DBEAFE"
                    android:textColorHint="#64748B"
                    android:textSize="12sp" />

                <com.fffcccdfgh.androidclicker.ProgramCodeScrollBar
                    android:id="@+id/programCodeScrollBar"
                    android:layout_width="12dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="插入工具"
                android:textColor="#94A3B8"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/programInsertTools"
                android:layout_width="match_parent"
                android:layout_height="86dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/floating_control_bg"
                android:orientation="vertical"
                android:padding="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/programPickTapButton"
                        style="@style/FloatingControlSecondaryPill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:text="@string/program_pick_tap"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/programPickCoordButton"
                        style="@style/FloatingControlSecondaryPill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:text="@string/program_pick_coord"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/programPickSwipeButton"
                        style="@style/FloatingControlSecondaryPill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:text="@string/program_pick_swipe"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="6dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/programPickAreaButton"
                        style="@style/FloatingControlSecondaryPill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:text="@string/program_pick_area"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/programPickColorButton"
                        style="@style/FloatingControlSecondaryPill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:text="@string/program_pick_color"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/testParseButton"
                    style="@style/FloatingControlWarningPill"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/test_parse" />

                <TextView
                    android:id="@+id/programSaveButton"
                    style="@style/FloatingControlSuccessPill"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="@string/save" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
