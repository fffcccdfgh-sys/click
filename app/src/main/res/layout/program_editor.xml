<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:background="@drawable/floating_control_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/programEditorTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/program_editor_title"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="center" />

    <EditText
        android:id="@+id/programCodeInput"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:textColor="@android:color/black"
        android:textColorHint="#888888"
        android:hint="@string/program_code_hint"
        android:textSize="12sp"
        android:background="#FFFFFF"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="top|start"
        android:inputType="textMultiLine|textNoSuggestions"
        android:scrollbars="vertical"
        android:maxLength="4096"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/templateButton"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/insert_template"
            android:textColor="#FF2196F3"
            android:textSize="13sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/testParseButton"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/test_parse"
            android:textColor="#FFFFC107"
            android:textSize="13sp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_delay_before"
        android:textColor="#CCCCCC"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/programDelayInput"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:textColor="@android:color/black"
        android:textColorHint="#888888"
        android:hint="1"
        android:textSize="13sp"
        android:background="#FFFFFF"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:inputType="number"
        android:maxLength="8"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_repeat_count"
        android:textColor="#CCCCCC"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/programRepeatInput"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:textColor="@android:color/black"
        android:textColorHint="#888888"
        android:hint="@string/settings_repeat_count_hint"
        android:textSize="13sp"
        android:background="#FFFFFF"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:inputType="number"
        android:maxLength="8"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/programCancelButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/cancel"
            android:textColor="#FFFF8888"
            android:textSize="14sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/programSaveButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/save"
            android:textColor="#FF4CAF50"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>
