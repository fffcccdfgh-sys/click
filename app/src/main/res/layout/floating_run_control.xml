<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/runFloatingRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/floating_control_bg"
    android:elevation="4dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <TextView
        android:id="@+id/runDragHandle"
        android:layout_width="76dp"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:paddingStart="4dp"
        android:paddingEnd="10dp"
        android:text="@string/run_label"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/runStartButton"
        style="@style/FloatingControlPrimaryPill"
        android:text="@string/start_action" />

    <TextView
        android:id="@+id/runCloseButton"
        style="@style/FloatingControlDangerPill"
        android:layout_marginStart="8dp"
        android:text="@string/close_button" />

</LinearLayout>
