<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/areaPickerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/areaPickerBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY" />

    <com.fffcccdfgh.androidclicker.core.picker.AreaSelectionView
        android:id="@+id/areaSelectionView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/areaPickerInstruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="40dp"
        android:background="@drawable/floating_panel_bg"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="@string/area_picker_instruction"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/areaPickerButtons"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_gravity="bottom"
        android:layout_margin="12dp"
        android:background="@drawable/picker_action_bar_bg"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="5dp"
        android:paddingVertical="5dp">

        <TextView
            android:id="@+id/areaPickerCancelBtn"
            android:layout_width="62dp"
            android:layout_height="30dp"
            android:background="@drawable/picker_action_cancel_bg"
            android:gravity="center"
            android:text="@string/cancel"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/areaPickerSaveBtn"
            android:layout_width="62dp"
            android:layout_height="30dp"
            android:background="@drawable/picker_action_save_bg"
            android:gravity="center"
            android:text="@string/save"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>
