<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/actionListPanel"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/floating_panel_bg"
    android:elevation="4dp"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:id="@+id/actionListPanelHeader"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/actionListHeader"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:paddingStart="4dp"
            android:paddingEnd="12dp"
            android:text="@string/action_list_empty"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/actionListCloseButton"
            style="@style/FloatingControlDangerPill"
            android:text="@string/close_button" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/actionListBody"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <ScrollView
            android:id="@+id/actionListScroll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:overScrollMode="ifContentScrolls"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/actionListContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <com.fffcccdfgh.androidclicker.ProgramTemplateMenuScrollBar
            android:id="@+id/actionListScrollBar"
            android:layout_width="8dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
