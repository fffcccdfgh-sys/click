<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="840dp"
    android:layout_height="wrap_content"
    android:background="@drawable/floating_control_bg"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="18dp"
    android:paddingEnd="22dp"
    android:paddingBottom="20dp">

    <TextView
        android:id="@+id/conditionTitle"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginBottom="18dp"
        android:gravity="center"
        android:text="@string/condition_title"
        android:textColor="@android:color/white"
        android:textSize="16sp" />

    <LinearLayout
        android:id="@+id/conditionTypeRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/conditionTypeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/condition_type_label"
            android:textColor="#DDDDDD"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/condTypeDropdown"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/condition_field_bg"
            android:clickable="true"
            android:drawableEnd="@drawable/ic_dropdown_arrow"
            android:drawablePadding="8dp"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="@string/condition_type_none"
            android:textColor="@android:color/black"
            android:textSize="15sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/conditionTextLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/condition_content_label"
        android:textColor="#DDDDDD"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/conditionContentRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/conditionTextInput"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/condition_field_bg"
            android:hint="@string/condition_text_hint"
            android:importantForAutofill="no"
            android:inputType="text"
            android:maxLength="256"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@android:color/black"
            android:textColorHint="#888888"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/condColorPickBtn"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/condition_field_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/condition_color_pick_btn"
            android:textColor="#FF2196F3"
            android:textSize="14sp"
            android:visibility="gone" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/conditionColorToleranceRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/conditionColorToleranceLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/condition_color_tolerance_label"
            android:textColor="#DDDDDD"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/conditionColorToleranceInput"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/condition_field_bg"
            android:hint="@string/condition_color_tolerance_hint"
            android:importantForAutofill="no"
            android:inputType="number"
            android:maxLength="3"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textColor="@android:color/black"
            android:textColorHint="#888888"
            android:textSize="15sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/conditionColorPosRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/conditionColorPosLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/condition_color_pos_label"
            android:textColor="#DDDDDD"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/condColorPosText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/condition_color_pos_text_none"
            android:textColor="#AAAAAA"
            android:textSize="13sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/condColorPosPickBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/condition_field_bg"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="@string/condition_color_pos_pick"
        android:textColor="#FF2196F3"
        android:textSize="14sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/conditionAreaSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/conditionAreaLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/condition_area_label"
                android:textColor="#DDDDDD"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/condAreaRangeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/condition_area_none"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/condAreaButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/condAreaFullscreenBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/condition_area_fullscreen"
                android:textColor="#FF4CAF50"
                android:textSize="14sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/condAreaCustomBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/condition_area_custom"
                android:textColor="#CCCCCC"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/condAreaControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/condSelectAreaBtn"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/condition_select_area"
                    android:textColor="#FF2196F3"
                    android:textSize="14sp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="22dp"
                    android:background="#33FFFFFF" />

                <TextView
                    android:id="@+id/condClearAreaBtn"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/condition_clear_area"
                    android:textColor="#FFFF8888"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/condInvertBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/condition_invert"
            android:textColor="#CCCCCC"
            android:textSize="14sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="26dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/condCancelBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/cancel"
            android:textColor="#FFAAAAAA"
            android:textSize="15sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="26dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/condSaveBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/save"
            android:textColor="#FF4CAF50"
            android:textSize="15sp" />

    </LinearLayout>

</LinearLayout>
