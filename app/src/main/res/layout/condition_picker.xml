<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/floating_panel_bg"
    android:elevation="4dp"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:id="@+id/conditionHeader"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/conditionTitle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:paddingStart="4dp"
            android:paddingEnd="12dp"
            android:text="@string/condition_title"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/conditionCloseButton"
            style="@style/FloatingControlDangerPill"
            android:text="@string/close_button" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/conditionTypeRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/conditionTypeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/condition_type_label"
            android:textColor="#CBD5E1"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/condTypeDropdown"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/floating_input_bg"
            android:clickable="true"
            android:drawableEnd="@drawable/ic_dropdown_arrow"
            android:drawablePadding="8dp"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="@string/condition_type_none"
            android:textColor="#334155"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/conditionTextLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/condition_content_label"
        android:textColor="#CBD5E1"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/conditionContentRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/conditionTextInput"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/floating_input_bg"
            android:hint="@string/condition_text_hint"
            android:importantForAutofill="no"
            android:inputType="text"
            android:maxLength="256"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textColor="#334155"
            android:textColorHint="#64748B"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/condColorPickBtn"
            style="@style/FloatingControlSecondaryPill"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="@string/condition_color_pick_btn"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/conditionOcrFilterRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/conditionOcrFilterLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/condition_ocr_filter_label"
            android:textColor="#CBD5E1"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/condOcrFilterDropdown"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/floating_input_bg"
            android:clickable="true"
            android:drawableEnd="@drawable/ic_dropdown_arrow"
            android:drawablePadding="8dp"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="@string/condition_ocr_filter_threshold"
            android:textColor="#334155"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/conditionTextAreaRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/condSelectAreaBtn"
            style="@style/FloatingControlSecondaryPill"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/condition_select_area"
            android:visibility="gone" />

        <TextView
            android:id="@+id/condAreaRangeText"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/floating_input_bg"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="@string/condition_area_none"
            android:textColor="#64748B"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/conditionColorToleranceRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/conditionColorToleranceLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/condition_color_tolerance_label"
            android:textColor="#CBD5E1"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/conditionColorToleranceInput"
            android:layout_width="92dp"
            android:layout_height="40dp"
            android:background="@drawable/floating_input_bg"
            android:gravity="center"
            android:hint="@string/condition_color_tolerance_hint"
            android:importantForAutofill="no"
            android:inputType="number"
            android:maxLength="3"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textColor="#334155"
            android:textColorHint="#64748B"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/conditionColorPosRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/conditionColorPosLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/condition_color_pos_label"
            android:textColor="#CBD5E1"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/condColorPosText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/condition_color_pos_text_none"
            android:textColor="#94A3B8"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/condColorPosPickBtn"
        style="@style/FloatingControlSecondaryPill"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="10dp"
        android:text="@string/condition_color_pos_pick"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/condInvertBtn"
            style="@style/FloatingControlSecondaryPill"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/condition_invert" />

        <TextView
            android:id="@+id/condSaveBtn"
            style="@style/FloatingControlSuccessPill"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="@string/save" />
    </LinearLayout>
</LinearLayout>
