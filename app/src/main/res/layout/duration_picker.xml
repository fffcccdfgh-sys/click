<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/durationPickerRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/floating_panel_bg"
    android:elevation="4dp"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/durationPickerDragHandle"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:text="@string/pick_wait_duration"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/durationContainer"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText
            android:id="@+id/waitDurationInput"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:background="@drawable/floating_input_bg"
            android:gravity="center_vertical"
            android:hint="@string/wait_duration_input_hint"
            android:inputType="number"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:singleLine="true"
            android:text="1000"
            android:textColor="#111827"
            android:textColorHint="#94A3B8"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/waitDurationCancelButton"
                style="@style/FloatingControlMenuPill"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="@string/cancel" />

            <TextView
                android:id="@+id/waitDurationSaveButton"
                style="@style/FloatingControlMenuPill"
                android:layout_width="0dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/save" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
