<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pvzCalibrationPanel"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/floating_panel_bg"
    android:elevation="4dp"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:id="@+id/pvzCalibrationHeader"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/pvzCalibrationDragHandle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:paddingStart="4dp"
            android:paddingEnd="12dp"
            android:text="@string/pvz_calibration_title"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pvzCalibrationCloseButton"
            style="@style/FloatingControlDangerPill"
            android:text="@string/close_button" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/pvzCalibrationEntryScroll"
        android:layout_width="324dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fillViewport="false"
        android:overScrollMode="ifContentScrolls"
        android:scrollbars="vertical">

        <LinearLayout
            android:id="@+id/pvzCalibrationEntryContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/floating_pill_secondary"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="@string/pvz_calibration_plant_slots"
                    android:textColor="#F8FAFC"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pvzCalibrationPlantSlotsStatus"
                    android:layout_width="76dp"
                    android:layout_height="30dp"
                    android:gravity="center"
                    android:text="@string/pvz_calibration_uncalibrated"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/floating_pill_secondary"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="@string/pvz_calibration_board"
                    android:textColor="#F8FAFC"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pvzCalibrationBoardStatus"
                    android:layout_width="76dp"
                    android:layout_height="30dp"
                    android:gravity="center"
                    android:text="@string/pvz_calibration_uncalibrated"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/floating_pill_secondary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="@string/pvz_calibration_sun"
                android:textColor="#F8FAFC"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pvzCalibrationSunStatus"
                android:layout_width="76dp"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="@string/pvz_calibration_uncalibrated"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/floating_pill_secondary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="@string/pvz_calibration_plant_food"
                android:textColor="#F8FAFC"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pvzCalibrationPlantFoodStatus"
                android:layout_width="76dp"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="@string/pvz_calibration_uncalibrated"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/floating_pill_secondary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="@string/pvz_calibration_artifact"
                android:textColor="#F8FAFC"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pvzCalibrationArtifactStatus"
                android:layout_width="76dp"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="@string/pvz_calibration_uncalibrated"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/floating_pill_secondary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="@string/pvz_calibration_cucumber"
                android:textColor="#F8FAFC"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pvzCalibrationCucumberStatus"
                android:layout_width="76dp"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="@string/pvz_calibration_uncalibrated"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/floating_pill_secondary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="@string/pvz_calibration_recharge"
                android:textColor="#F8FAFC"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pvzCalibrationRechargeStatus"
                android:layout_width="76dp"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="@string/pvz_calibration_uncalibrated"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/floating_pill_secondary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="@string/pvz_calibration_cards"
                android:textColor="#F8FAFC"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pvzCalibrationCardsStatus"
                android:layout_width="76dp"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="@string/pvz_calibration_uncalibrated"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/floating_pill_secondary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="@string/pvz_calibration_other"
                android:textColor="#F8FAFC"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pvzCalibrationOtherStatus"
                android:layout_width="76dp"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="@string/pvz_calibration_uncalibrated"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
