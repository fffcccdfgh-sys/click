<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pvzProgramEditorRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/floating_panel_bg"
    android:elevation="4dp"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/pvzProgramEditorHeader"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/pvzProgramEditorTitle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:paddingStart="4dp"
            android:paddingEnd="12dp"
            android:text="@string/pvz_program_editor_title"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pvzProgramCloseButton"
            style="@style/FloatingControlDangerPill"
            android:text="@string/close_button" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/pvzProgramEditToolbar"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/floating_control_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <TextView
            android:id="@+id/pvzProgramSelectAllButton"
            style="@style/FloatingControlSecondaryPill"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="@string/program_edit_select_all"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/pvzProgramCopyButton"
            style="@style/FloatingControlSecondaryPill"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="@string/program_edit_copy"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/pvzProgramCutButton"
            style="@style/FloatingControlWarningPill"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="@string/program_edit_cut"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/pvzProgramPasteButton"
            style="@style/FloatingControlSuccessPill"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="@string/program_edit_paste"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/pvzProgramCodePanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:background="@drawable/floating_control_bg"
        android:orientation="horizontal"
        android:padding="8dp">

        <com.fffcccdfgh.androidclicker.ProgramLineNumberView
            android:id="@+id/pvzProgramLineNumbers"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp" />

        <com.fffcccdfgh.androidclicker.ProgramCodeEditText
            android:id="@+id/pvzProgramCodeInput"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#0B1020"
            android:gravity="top|start"
            android:inputType="textMultiLine|textNoSuggestions"
            android:overScrollMode="always"
            android:paddingStart="10dp"
            android:paddingTop="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="10dp"
            android:scrollbars="none"
            android:textColor="#DBEAFE"
            android:textSize="12sp" />

        <com.fffcccdfgh.androidclicker.ProgramCodeScrollBar
            android:id="@+id/pvzProgramCodeScrollBar"
            android:layout_width="12dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/pvzTestParseButton"
            style="@style/FloatingControlWarningPill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/test_parse" />

        <TextView
            android:id="@+id/pvzProgramSaveButton"
            style="@style/FloatingControlSuccessPill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="@string/save" />
    </LinearLayout>
</LinearLayout>
