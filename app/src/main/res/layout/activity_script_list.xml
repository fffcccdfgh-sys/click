<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F6FB"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="28dp"
    android:paddingEnd="24dp"
    android:paddingBottom="18dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/script_list_title"
        android:textColor="#111827"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="&#x8FD0;&#x884C;&#x3001;&#x7F16;&#x8F91;&#x3001;&#x91CD;&#x547D;&#x540D;&#x3001;&#x5206;&#x4EAB;&#x548C;&#x5BFC;&#x5165; Lua &#x6587;&#x4EF6;"
        android:textColor="#64748B"
        android:textSize="15sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="22dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="14dp">

        <LinearLayout
            android:id="@+id/scriptListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

    <TextView
        android:id="@+id/importScriptButton"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/script_import_button_bg"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="@string/import_script"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold" />

</LinearLayout>
