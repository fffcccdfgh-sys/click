<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pickerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#30000000">

    <com.fffcccdfgh.androidclicker.core.picker.PointPickerOverlayView
        android:id="@+id/pointPickerOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <com.fffcccdfgh.androidclicker.core.picker.SwipePickerOverlayView
        android:id="@+id/swipePickerOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <TextView
        android:id="@+id/pickerInstruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="#CC000000"
        android:gravity="center"
        android:padding="32dp"
        android:text="@string/pick_position_instruction"
        android:textColor="@android:color/white"
        android:textSize="18sp" />

</FrameLayout>
