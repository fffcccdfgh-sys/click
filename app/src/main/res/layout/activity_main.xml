<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/main_page_padding_horizontal"
        android:paddingTop="@dimen/main_page_padding_top"
        android:paddingEnd="@dimen/main_page_padding_horizontal"
        android:paddingBottom="@dimen/main_page_padding_bottom">

        <LinearLayout
            android:id="@+id/mainContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="@dimen/main_content_max_width">

            <TextView
                android:id="@+id/appTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/main_app_title"
                android:textColor="#0F172A"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/appSubtitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/main_subtitle"
                android:textColor="#64748B"
                android:textSize="17sp" />

            <FrameLayout
                android:id="@+id/mainStartArea"
                android:layout_width="match_parent"
                android:layout_height="@dimen/main_start_area_height"
                android:layout_marginTop="24dp">

                <TextView
                    android:id="@+id/toggleFloatingButton"
                    android:layout_width="@dimen/main_start_button_size"
                    android:layout_height="@dimen/main_start_button_size"
                    android:layout_gravity="center"
                    android:background="@drawable/main_start_circle_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:padding="0dp"
                    android:text="@string/start_floating_control"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/gameScriptsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/main_card_gap"
                android:background="@drawable/main_card_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/main_card_padding">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="游戏脚本"
                        android:textColor="#111827"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="植物大战僵尸2专用"
                        android:textColor="#64748B"
                        android:textSize="15sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/gameScriptsButton"
                    android:layout_width="@dimen/main_game_button_size"
                    android:layout_height="@dimen/main_game_button_size"
                    android:layout_marginStart="18dp"
                    android:background="@drawable/main_game_open_circle_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:padding="0dp"
                    android:text="进入"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/permissionsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/main_card_gap"
                android:background="@drawable/main_card_bg"
                android:orientation="vertical"
                android:padding="@dimen/main_card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/main_permissions_title"
                    android:textColor="#111827"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/main_permission_row_gap"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/main_permission_number_bg"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="#4F46E5"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:text="@string/main_accessibility_title"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/openSettingsButton"
                        android:layout_width="@dimen/main_permission_status_width"
                        android:layout_height="@dimen/main_permission_status_height"
                        android:background="@drawable/main_permission_action_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:padding="0dp"
                        android:text="@string/main_permission_open"
                        android:textColor="#2563EB"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/main_permission_row_gap"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/main_permission_number_bg"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="#4F46E5"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:text="@string/main_overlay_title"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/openOverlaySettingsButton"
                        android:layout_width="@dimen/main_permission_status_width"
                        android:layout_height="@dimen/main_permission_status_height"
                        android:background="@drawable/main_permission_action_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:padding="0dp"
                        android:text="@string/main_permission_open"
                        android:textColor="#2563EB"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/main_permission_row_gap"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/main_permission_number_bg"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="#4F46E5"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/screenCaptureStatusText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:text="@string/main_screen_capture_title"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/grantScreenCaptureButton"
                        android:layout_width="@dimen/main_permission_status_width"
                        android:layout_height="@dimen/main_permission_status_height"
                        android:background="@drawable/main_permission_action_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:padding="0dp"
                        android:text="@string/main_permission_open"
                        android:textColor="#2563EB"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/scriptsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/main_card_gap"
                android:background="@drawable/main_card_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/main_card_padding">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/my_scripts"
                        android:textColor="#111827"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/main_scripts_subtitle"
                        android:textColor="#64748B"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:text="@string/main_scripts_list_title"
                        android:textColor="#111827"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/main_scripts_actions"
                        android:textColor="#64748B"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/myScriptsButton"
                    android:layout_width="@dimen/main_script_button_size"
                    android:layout_height="@dimen/main_script_button_size"
                    android:layout_marginStart="18dp"
                    android:background="@drawable/main_script_open_circle_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:padding="0dp"
                    android:text="@string/main_open"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/deviceResolutionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="14dp"
                android:text="@string/main_device_resolution_unknown"
                android:textColor="#2563EB"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
