<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floatingRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/floating_control_bg"
    android:orientation="vertical"
    android:padding="8dp"
    android:elevation="4dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/dragHandle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="12dp"
            android:text="@string/floating_control_label"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/startButton"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/start_action"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/addButton"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/add_action"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/listButton"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/list_action"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/closeButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="✕"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/addMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp"
        android:visibility="gone">

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tapOption"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/tap_action"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/swipeOption"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/swipe_action"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/waitOption"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/wait_action"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/clearOption"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/clear_action"
            android:textColor="#FF8888"
            android:textSize="13sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/actionListPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/actionListHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_list_empty"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:id="@+id/actionListContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/listAddTap"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/action_list_add_tap"
                android:textColor="@android:color/white"
                android:textSize="12sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/listAddSwipe"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/action_list_add_swipe"
                android:textColor="@android:color/white"
                android:textSize="12sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/listAddWait"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/action_list_add_wait"
                android:textColor="@android:color/white"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
