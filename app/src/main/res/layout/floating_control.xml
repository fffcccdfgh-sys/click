<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floatingRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/floating_control_bg"
    android:orientation="vertical"
    android:padding="8dp"
    android:elevation="4dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/dragHandle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="12dp"
            android:text="@string/floating_control_label"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/startButton"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/start_action"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/addButton"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/add_action"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/closeButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="✕"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/addMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp"
        android:visibility="gone">

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tapOption"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/tap_action"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/swipeOption"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/swipe_action"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

    </LinearLayout>

</LinearLayout>
