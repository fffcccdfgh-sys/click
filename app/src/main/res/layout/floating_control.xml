<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floatingRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/floating_control_bg"
    android:orientation="vertical"
    android:padding="8dp"
    android:elevation="4dp">

    <LinearLayout
        android:id="@+id/expandedControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/dragHandle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="12dp"
                android:text="@string/floating_control_label"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:maxEms="6"
                android:ellipsize="end"
                android:maxLines="1" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/startButton"
                android:layout_width="44dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/start_action"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/stopPositionButton"
                android:layout_width="44dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/stop_position_action"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/loopButton"
                android:layout_width="44dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/loop_button"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/addButton"
                android:layout_width="44dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/add_action"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/listButton"
                android:layout_width="44dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/list_action"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/saveButton"
                android:layout_width="44dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/save_action"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/positionButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="@string/position_show"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/closeButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="@string/close_button"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/foldButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="@string/fold"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/addMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tapOption"
                    android:layout_width="44dp"
                    android:layout_height="36dp"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/tap_action"
                    android:textColor="@android:color/white"
                    android:textSize="13sp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="#33FFFFFF" />

                <TextView
                    android:id="@+id/swipeOption"
                    android:layout_width="44dp"
                    android:layout_height="36dp"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/swipe_action"
                    android:textColor="@android:color/white"
                    android:textSize="13sp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="#33FFFFFF" />

                <TextView
                    android:id="@+id/waitOption"
                    android:layout_width="44dp"
                    android:layout_height="36dp"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/wait_action"
                    android:textColor="@android:color/white"
                    android:textSize="13sp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="#33FFFFFF" />

                <TextView
                    android:id="@+id/programOption"
                    android:layout_width="44dp"
                    android:layout_height="36dp"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/program_action"
                    android:textColor="@android:color/white"
                    android:textSize="13sp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="#33FFFFFF" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/loopSettingsPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="3dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/loop_count_label"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/loopCountInput"
                        android:layout_width="72dp"
                        android:layout_height="32dp"
                        android:textColor="@android:color/black"
                        android:textColorHint="#888888"
                        android:hint="@string/loop_count_hint"
                        android:textSize="13sp"
                        android:background="#FFFFFF"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:inputType="number"
                        android:maxLength="8"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/loop_gap_label"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/loopGapInput"
                        android:layout_width="72dp"
                        android:layout_height="32dp"
                        android:textColor="@android:color/black"
                        android:textColorHint="#888888"
                        android:hint="0"
                        android:textSize="13sp"
                        android:background="#FFFFFF"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:inputType="number"
                        android:maxLength="8"
                        android:layout_marginStart="6dp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/loopSettingsSave"
                android:layout_width="48dp"
                android:layout_height="64dp"
                android:gravity="center"
                android:text="@string/save"
                android:textColor="#FF4CAF50"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true"
                android:background="@android:color/transparent"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionListPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/actionListHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_list_empty"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:id="@+id/actionListBody"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ScrollView
                    android:id="@+id/actionListScroll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:overScrollMode="ifContentScrolls"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/actionListContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </ScrollView>

                <com.fffcccdfgh.androidclicker.ProgramTemplateMenuScrollBar
                    android:id="@+id/actionListScrollBar"
                    android:layout_width="8dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/saveConfirmPanel"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/confirm_save"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/saveNameInput"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:textColor="@android:color/white"
                android:textColorHint="#AAAAAA"
                android:textSize="13sp"
                android:background="#333333"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:maxLines="1"
                android:inputType="text"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/saveConfirmYes"
                    android:layout_width="56dp"
                    android:layout_height="34dp"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/yes"
                    android:textColor="#FF4CAF50"
                    android:textSize="13sp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:background="#33FFFFFF" />

                <TextView
                    android:id="@+id/saveConfirmNo"
                    android:layout_width="56dp"
                    android:layout_height="34dp"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/no"
                    android:textColor="#FFFF8888"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/collapsedControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/collapsedTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="12dp"
            android:text="@string/floating_control_label"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/collapsedStartButton"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/start_action"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/collapsedCloseButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="@string/close_button"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/collapsedExpandButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="@string/expand"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

    </LinearLayout>

</LinearLayout>
