<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/addPanelRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/floating_panel_bg"
    android:elevation="4dp"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/addPanelDragHandle"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:text="@string/add_action"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tapOption"
            style="@style/FloatingControlMenuPill"
            android:text="@string/tap_action" />

        <TextView
            android:id="@+id/swipeOption"
            style="@style/FloatingControlMenuPill"
            android:layout_marginStart="8dp"
            android:text="@string/swipe_action" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/waitOption"
            style="@style/FloatingControlMenuPill"
            android:text="@string/wait_action" />

        <TextView
            android:id="@+id/programOption"
            style="@style/FloatingControlMenuPill"
            android:layout_marginStart="8dp"
            android:text="@string/program_action" />
    </LinearLayout>
</LinearLayout>
